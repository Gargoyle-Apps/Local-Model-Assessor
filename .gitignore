# Cursor IDE
.cursorignore

# Agent/IDE app runtime dirs (generated on-demand)
.continue/
.opencode/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors/IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# If Python scripts are added
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/

# If Node tooling is added
node_modules/
package-lock.json

# Logs and temp files
*.log
*.tmp
*.bak

# Local testing/scratch files
scratch/
test/
local/

ref/

# Cursor rules (user-specific)
.cursorrules

# Local-only files (gitignored)
computer-profile/hardware-profile.yaml
computer-profile/software-profile.yaml
model-data/model-assessor.db
model-data/assessed-models.md
model-data/new-models.yaml
model-data/*.db

# Ollama Modelfile workspace: keep directory, ignore generated .mf / Modelfile contents
model-data/modelfile/*
!model-data/modelfile/.gitkeep

# Legacy (if still present locally)
model-data/model-lookup.json

# IDE config copies (local references; generated on-demand)
integrations/IDE-model-management/continue/config.yaml
integrations/IDE-model-management/opencode/opencode.json
integrations/IDE-model-management/goose/config.yaml
integrations/IDE-model-management/pi/settings.json
integrations/IDE-model-management/pi/models.json
integrations/IDE-model-management/zed/settings.json
integrations/IDE-model-management/cline/provider-settings.json

# Stack handoff generator output (copy-out artifacts)
integrations/embed-retrieval-stack/out/

# OpenCode (project-level config is local)
opencode.json
opencode.jsonc