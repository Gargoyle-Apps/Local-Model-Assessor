# Cursor IDE
.cursorignore

# Continue: override global .gitignore_global which ignores all of .continue/
# Track the rules directory (project knowledge); keep config.yaml local
!.continue/
.continue/*
!.continue/rules/
!.continue/rules/**

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors/IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# If Python scripts are added
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/

# If Node tooling is added
node_modules/
package-lock.json

# Logs and temp files
*.log
*.tmp
*.bak

# Local testing/scratch files
scratch/
test/
local/

ref/

# Cursor rules (user-specific)
.cursorrules

# Local-only files (gitignored)
computer-profile/hardware-profile.yaml
computer-profile/software-profile.yaml
model-data/model-assessor.db
model-data/assessed-models.md
model-data/new-models.yaml
model-data/*.db

# Legacy (if still present locally)
model-data/model-lookup.json

# Agent configs (local copies; template stays in repo)
agent-model-management/continue/config.yaml